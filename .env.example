# Frontend Environment Variables for Maplorix

# API Configuration
VITE_API_URL=http://localhost:4000/api

# App Configuration
VITE_APP_NAME=Maplorix
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_DASHBOARD=true
VITE_ENABLE_JOB_POSTING=true
VITE_ENABLE_APPLICATIONS=true

# External Services (if needed)
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_RECAPTCHA_SITE_KEY=

# reCAPTCHA Configuration
# Get your site key from: https://www.google.com/recaptcha/admin/create
# For development, you can use test key: 6LeIxAcTAAAAAJcZVRqyHh71UMIEbQjQ5y3FkT_y
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
